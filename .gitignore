# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Test and tooling caches
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Local input/reference data
input/*
!input/.gitkeep
reference/*
!reference/.gitkeep

# Local runtime output
logs/*
!logs/.gitkeep
output/*
!output/.gitkeep

# Editor and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db
